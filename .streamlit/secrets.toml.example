# Szablon sekretow dla Streamlit Community Cloud.
# NIE wpisuj tu prawdziwych kluczy i NIE commituj pliku secrets.toml.
#
# Lokalnie: skopiuj do .streamlit/secrets.toml i uzupelnij,
#   albo ustaw zmienne srodowiskowe o tych samych nazwach.
# W chmurze: wklej ponizsze linie w panelu "Secrets" aplikacji na share.streamlit.io.

# --- Research AI (wymagane dla ocen jakosciowych i deep researchu) ---
# Darmowy klucz Google Gemini: https://aistudio.google.com/apikey (bez karty kredytowej)
GEMINI_API_KEY = "..."

# --- Listy obserwacyjne: trwaly zapis w GitHub Gist (zalecane w chmurze) ---
# 1. Token: https://github.com/settings/tokens -> Generate new token (classic)
#    -> zaznacz TYLKO scope "gist" -> skopiuj.
# 2. GIST_ID ponizej wskazuje na prywatny gist utworzony dla tego projektu.
GITHUB_TOKEN = "ghp_..."
GIST_ID = "32a3baae6b7f8aaa8e8fc6be2877b5f3"

# --- Opcjonalnie: inny provider dla szybkiego researchu (ai_research.py) ---
# Kod uzywa klienta OpenAI, wiec dziala z kazdym API zgodnym z OpenAI.
# LLM_BASE_URL = "https://generativelanguage.googleapis.com/v1beta/openai/"
# LLM_MODEL = "gemini-flash-latest"
