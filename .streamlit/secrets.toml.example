# Szablon sekretow dla Streamlit Community Cloud.
# NIE wpisuj tu prawdziwego klucza i NIE commituj pliku secrets.toml.
#
# Lokalnie: skopiuj ten plik do .streamlit/secrets.toml i wstaw klucz,
#   albo ustaw zmienna srodowiskowa GEMINI_API_KEY.
# W chmurze: wklej ponizsza linie w panelu "Secrets" aplikacji na share.streamlit.io.

# Darmowy klucz Google Gemini: https://aistudio.google.com/apikey (bez karty kredytowej)
GEMINI_API_KEY = "..."

# Opcjonalnie: przekierowanie na innego providera kompatybilnego z OpenAI
# (np. Groq, OpenRouter, OpenAI). Domyslnie ustawiony jest endpoint Gemini.
# LLM_BASE_URL = "https://generativelanguage.googleapis.com/v1beta/openai/"
# LLM_MODEL = "gemini-flash-latest"
