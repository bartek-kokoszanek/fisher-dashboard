# Szablon sekretow dla Streamlit Community Cloud.
# NIE wpisuj tu prawdziwego klucza i NIE commituj pliku secrets.toml.
#
# Lokalnie: skopiuj ten plik do .streamlit/secrets.toml i wstaw klucz,
#   albo ustaw zmienna srodowiskowa ANTHROPIC_API_KEY.
# W chmurze: wklej ponizsza linie w panelu "Secrets" aplikacji na share.streamlit.io.

ANTHROPIC_API_KEY = "sk-ant-..."
